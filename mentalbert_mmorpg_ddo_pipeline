        "# CELL 3 Helper functions\n",
        "\n",
        "def sha256_short(value: str, length: int = 16) -> str:\n",
        "    \"\"\"\n",
        "    Create a short pseudonymous identifier from a string value.\n",
        "    \"\"\"\n",
        "    if pd.isna(value):\n",
        "        value = \"missing\"\n",
        "    value = str(value)\n",
        "    return hashlib.sha256(value.encode(\"utf-8\")).hexdigest()[:length]\n",
        "\n",
        "\n",
        "def remove_personal_identifiers(text: str) -> str:\n",
        "    \"\"\"\n",
        "    Remove directly identifying or platform-specific strings from text.\n",
        "    \"\"\"\n",
        "    if not isinstance(text, str):\n",
        "        return \"\"\n",
        "\n",
        "    text = re.sub(r\"\\S+@\\S+\\s?\", \" \", text)\n",
        "    text = re.sub(r\"http\\S+|www\\.\\S+\", \" \", text)\n",
        "    text = re.sub(r\"\\br/[A-Za-z0-9_]+\\b\", \" \", text)\n",
        "    text = re.sub(r\"\\bu/[A-Za-z0-9_]+\\b\", \" \", text)\n",
        "    text = text.replace(\"[removed]\", \" \").replace(\"[deleted]\", \" \")\n",
        "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
        "    return text\n",
        "\n",
        "\n",
        "def contains_addiction_marker(text: str) -> bool:\n",
        "    \"\"\"\n",
        "    Conservative lexical filter used for the strict lexical-exclusion control condition.\n",
        "    \"\"\"\n",
        "    pattern = re.compile(r\"(?i)\\b(addict|addicted|addiction|addictive|hooked)\\b\")\n",
        "    return bool(pattern.search(str(text)))\n",
        "\n",
        "\n",
        "def mean_pooling(last_hidden_state: torch.Tensor, attention_mask: torch.Tensor) -> torch.Tensor:\n",
        "    \"\"\"\n",
        "    Compute attention-mask-aware mean pooling over token embeddings.\n",
        "    \"\"\"\n",
        "    mask = attention_mask.unsqueeze(-1).expand(last_hidden_state.size()).float()\n",
        "    masked_embeddings = last_hidden_state * mask\n",
        "    summed = masked_embeddings.sum(dim=1)\n",
        "    counts = mask.sum(dim=1).clamp(min=1e-9)\n",
        "    return summed / counts\n",
        "\n",
        "\n",
        "def compute_cohens_d(x1: np.ndarray, x0: np.ndarray) -> float:\n",
        "    \"\"\"\n",
        "    Compute Cohen's d for two independent groups.\n",
        "    \"\"\"\n",
        "    pooled_std = np.sqrt((np.std(x1, ddof=1) ** 2 + np.std(x0, ddof=1) ** 2) / 2)\n",
        "    if pooled_std == 0:\n",
        "        return np.nan\n",
        "    return (np.mean(x1) - np.mean(x0)) / pooled_std"
      ],
