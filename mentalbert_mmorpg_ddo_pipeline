        "#CELL 22 — Helper function for RQ1 PCA and t-tests\n",
        "def run_rq1_pca_tests(df_input: pd.DataFrame, X: np.ndarray, run_name: str, output_prefix: str):\n",
        "    y = df_input[\"label\"].astype(int).values\n",
        "\n",
        "    pca = PCA(n_components=N_COMPONENTS, random_state=RANDOM_STATE)\n",
        "    X_pca = pca.fit_transform(X)\n",
        "\n",
        "    pc_cols = [f\"PC{i+1}\" for i in range(N_COMPONENTS)]\n",
        "    pc_df = pd.DataFrame(X_pca, columns=pc_cols)\n",
        "    pc_df[\"label\"] = y\n",
        "\n",
        "    t_vals, p_vals, cohen_ds = [], [], []\n",
        "\n",
        "    for col in pc_cols:\n",
        "        x1 = pc_df.loc[pc_df[\"label\"] == 1, col].values\n",
        "        x0 = pc_df.loc[pc_df[\"label\"] == 0, col].values\n",
        "\n",
        "        t_stat, p_val = ttest_ind(x1, x0, equal_var=False)\n",
        "        d = compute_cohens_d(x1, x0)\n",
        "\n",
        "        t_vals.append(t_stat)\n",
        "        p_vals.append(p_val)\n",
        "        cohen_ds.append(d)\n",
        "\n",
        "    fdr_signif, fdr_pvals = fdrcorrection(p_vals, alpha=0.05)\n",
        "\n",
        "    results = pd.DataFrame({\n",
        "        \"PC\": np.arange(1, N_COMPONENTS + 1),\n",
        "        \"t_stat\": t_vals,\n",
        "        \"p_value\": p_vals,\n",
        "        \"Cohen_d\": cohen_ds,\n",
        "        \"FDR_p\": fdr_pvals,\n",
        "        \"Significant_FDR\": fdr_signif\n",
        "    })\n",
        "\n",
        "    centroid_1 = X[y == 1].mean(axis=0)\n",
        "    centroid_0 = X[y == 0].mean(axis=0)\n",
        "    cos_dist = cosine(centroid_1, centroid_0)\n",
        "\n",
        "    results_path = BASE_DIR / f\"{output_prefix}_ttest_results.csv\"\n",
        "    pca_scores_path = BASE_DIR / f\"{output_prefix}_pca_scores.csv\"\n",
        "\n",
        "    results.to_csv(results_path, index=False)\n",
        "    pc_df.to_csv(pca_scores_path, index=False)\n",
        "\n",
        "    print(f\"{run_name}\")\n",
