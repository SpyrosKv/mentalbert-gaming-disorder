      "source": [
        "#CELL 17 — Build RQ1 Run 3 dataset: length-matched control\n",
        "run1_base = run1_df.copy()\n",
        "run1_base[\"text_len\"] = run1_base[\"full_text\"].str.len()\n",
        "\n",
        "run1_add = run1_base[run1_base[\"label\"] == 1].copy()\n",
        "run1_non = run1_base[run1_base[\"label\"] == 0].copy()\n",
        "\n",
        "run1_add[\"len_bin\"] = pd.qcut(run1_add[\"text_len\"], q=5, labels=False, duplicates=\"drop\")\n",
        "run1_non[\"len_bin\"] = pd.qcut(run1_non[\"text_len\"], q=5, labels=False, duplicates=\"drop\")\n",
        "\n",
        "matched_controls = []\n",
        "\n",
        "for b in sorted(run1_add[\"len_bin\"].dropna().unique()):\n",
        "    add_bin = run1_add[run1_add[\"len_bin\"] == b]\n",
        "    non_bin = run1_non[run1_non[\"len_bin\"] == b]\n",
        "\n",
        "    n_sample = min(len(add_bin), len(non_bin))\n",
        "    if n_sample == 0:\n",
        "        continue\n",
        "\n",
        "    sampled = non_bin.sample(n=n_sample, random_state=RANDOM_STATE, replace=False)\n",
        "    matched_controls.append(sampled)\n",
        "\n",
        "run3_control_df = pd.concat(matched_controls, ignore_index=True)\n",
        "run3_df = pd.concat([run1_add, run3_control_df], ignore_index=True)\n",
