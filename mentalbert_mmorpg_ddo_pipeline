        "    print(f\"Cosine distance: {cos_dist:.6f}\")\n",
        "\n",
        "    return {\n",
        "        \"pca\": pca,\n",
        "        \"pc_df\": pc_df,\n",
        "        \"results\": results,\n",
        "        \"cosine_distance\": cos_dist\n",
